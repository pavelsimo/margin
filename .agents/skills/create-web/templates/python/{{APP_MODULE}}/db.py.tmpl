"""Database engine and sessions. Importing this module registers the SQLite PRAGMA listener."""

import os
import sqlite3
from typing import Any

import sqlmodel
from sqlalchemy import event
from sqlalchemy.engine import Engine

DEFAULT_DB_URL = "sqlite:///{{APP_MODULE}}.db"


@event.listens_for(Engine, "connect")
def _set_sqlite_pragmas(dbapi_connection: Any, _connection_record: Any) -> None:
    if not isinstance(dbapi_connection, sqlite3.Connection):
        return
    cursor = dbapi_connection.cursor()
    cursor.execute("PRAGMA journal_mode=WAL")
    cursor.execute("PRAGMA synchronous=NORMAL")
    cursor.execute("PRAGMA busy_timeout=5000")
    cursor.execute("PRAGMA foreign_keys=ON")
    cursor.close()


engine = sqlmodel.create_engine(os.getenv("DATABASE_URL", DEFAULT_DB_URL))


def session() -> sqlmodel.Session:
    return sqlmodel.Session(engine)
