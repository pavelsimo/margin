[project]
name = "{{APP_NAME}}"
version = "0.1.0"
description = "{{DESCRIPTION}}"
requires-python = ">={{PYTHON_VERSION}}"
dependencies = [
    "reflex>=0.9",
    "fastapi>=0.115",
    "sqlmodel>=0.0.24",
    "alembic>=1.15",
]

[dependency-groups]
dev = [
    "pytest>=8.0",
    "pytest-cov>=5.0",
    "mypy>=1.10",
    "ruff>=0.6",
    "lefthook>=1.10",
]

[tool.uv]
package = false

[tool.ruff]
line-length = 120

[tool.ruff.lint]
select = ["E", "F", "I", "UP", "B", "SIM"]
ignore = ["E501"]

[tool.mypy]
strict = true
python_version = "{{PYTHON_VERSION}}"
files = ["{{APP_MODULE}}"]
disallow_untyped_decorators = false # @rx.page / @rx.event trip strict decorator checks

[[tool.mypy.overrides]]
module = "{{APP_MODULE}}.pages.*"
warn_return_any = false # rx components are lazily loaded and type as Any

[tool.pytest.ini_options]
testpaths = ["tests"]
addopts = "--cov={{APP_MODULE}} --cov-report=term-missing"

[tool.coverage.run]
branch = true
source = ["{{APP_MODULE}}"]
omit = ["*/pages/*", "*/state.py", "*/{{APP_MODULE}}.py", "*/seed.py"]

[tool.coverage.report]
fail_under = 70
show_missing = true
