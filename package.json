{
  "name": "margin-desktop",
  "version": "0.1.0",
  "description": "Margin: AI paper reader, desktop edition",
  "desktopName": "margin",
  "main": "out/main/index.js",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist": "electron-vite build && electron-builder --publish never",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@fontsource/source-serif-4": "^5.2.9",
    "@radix-ui/themes": "^3.3.0",
    "better-sqlite3": "^12.11.1",
    "katex": "^0.18.0",
    "mupdf": "^1.28.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  },
  "build": {
    "appId": "io.github.pavelsimo.margin",
    "productName": "Margin",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "artifactName": "${productName}-${version}-windows-${arch}.${ext}"
    },
    "mac": {
      "target": "dmg",
      "artifactName": "${productName}-${version}-macos-${arch}.${ext}"
    },
    "linux": {
      "target": "AppImage",
      "category": "Education",
      "executableName": "margin",
      "syncDesktopName": true,
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}"
    }
  }
}
